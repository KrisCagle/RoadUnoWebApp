VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google API Key Configuration
# Get a key from: https://console.cloud.google.com/google/maps-apis/credentials
VITE_GOOGLE_API_KEY=your_google_api_key_here

# AI Proxy Configuration
# Endpoint that proxies requests to OpenAI
VITE_AI_PROXY_ENDPOINT=https://your-proxy-endpoint-url

# Development Pro Plan Override
# WARNING: NEVER enable in production. For local development only.
DEV_FORCE_PRO_ENABLED=false
DEV_FORCE_PRO_EMAIL=founder@example.com